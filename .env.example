# Copy to .env and customise as needed.
# All values here can also be set via the dashboard at runtime.

# Override the default config file location
# VOICE_ASSISTANT_CONFIG_PATH=configs/default.yaml

# Override Ollama URL if not on localhost
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Server bind
HOST=0.0.0.0
PORT=8080
